{
  "$schema": "vscode://schemas/color-theme",
  "name": "VS2026 Nord",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "activityBar.background": "#2E3440",
    "activityBar.foreground": "#ECEFF4",
    "activityBar.inactiveForeground": "#D8DEE999",
    "activityBarBadge.background": "#5E81AC",
    "activityBarBadge.foreground": "#ECEFF4",
    "badge.background": "#4C566A",
    "badge.foreground": "#ECEFF4",
    "breadcrumb.background": "#2E3440",
    "breadcrumb.foreground": "#D8DEE9",
    "breadcrumb.focusForeground": "#88C0D0",
    "button.background": "#5E81AC",
    "button.foreground": "#ECEFF4",
    "button.hoverBackground": "#81A1C1",
    "checkbox.background": "#3B4252",
    "checkbox.border": "#4C566A",
    "dropdown.background": "#3B4252",
    "dropdown.border": "#4C566A",
    "dropdown.foreground": "#ECEFF4",
    "editor.background": "#2E3440",
    "editor.foreground": "#D8DEE9",
    "editor.findMatchBackground": "#EBCB8B66",
    "editor.findMatchHighlightBackground": "#EBCB8B33",
    "editor.lineHighlightBackground": "#3B4252",
    "editor.selectionBackground": "#434C5ECC",
    "editor.selectionHighlightBackground": "#434C5E88",
    "editorCursor.foreground": "#D8DEE9",
    "editorGroup.border": "#3B4252",
    "editorGroupHeader.tabsBackground": "#2E3440",
    "editorGutter.addedBackground": "#A3BE8C",
    "editorGutter.background": "#2E3440",
    "editorGutter.deletedBackground": "#BF616A",
    "editorGutter.modifiedBackground": "#EBCB8B",
    "editorIndentGuide.activeBackground1": "#D8DEE966",
    "editorIndentGuide.background1": "#4C566A66",
    "editorLineNumber.activeForeground": "#D8DEE9",
    "editorLineNumber.foreground": "#4C566A",
    "editorOverviewRuler.border": "#2E3440",
    "editorWidget.background": "#3B4252",
    "editorWidget.border": "#4C566A",
    "errorForeground": "#BF616A",
    "focusBorder": "#88C0D0",
    "foreground": "#D8DEE9",
    "input.background": "#3B4252",
    "input.border": "#4C566A",
    "input.foreground": "#ECEFF4",
    "input.placeholderForeground": "#D8DEE999",
    "list.activeSelectionBackground": "#434C5E",
    "list.activeSelectionForeground": "#ECEFF4",
    "list.focusBackground": "#434C5E",
    "list.highlightForeground": "#88C0D0",
    "list.hoverBackground": "#3B4252",
    "list.inactiveSelectionBackground": "#3B4252",
    "list.inactiveSelectionForeground": "#D8DEE9",
    "menu.background": "#3B4252",
    "menu.foreground": "#ECEFF4",
    "menu.selectionBackground": "#434C5E",
    "menu.selectionForeground": "#ECEFF4",
    "notificationCenterHeader.background": "#3B4252",
    "notifications.background": "#2E3440",
    "notifications.border": "#4C566A",
    "panel.background": "#2E3440",
    "panel.border": "#3B4252",
    "panelTitle.activeBorder": "#88C0D0",
    "panelTitle.activeForeground": "#ECEFF4",
    "panelTitle.inactiveForeground": "#D8DEE999",
    "peekView.border": "#88C0D0",
    "peekViewEditor.background": "#2E3440",
    "peekViewResult.background": "#3B4252",
    "pickerGroup.border": "#4C566A",
    "pickerGroup.foreground": "#88C0D0",
    "progressBar.background": "#88C0D0",
    "quickInput.background": "#3B4252",
    "quickInput.foreground": "#ECEFF4",
    "scrollbarSlider.activeBackground": "#4C566ACC",
    "scrollbarSlider.background": "#4C566A99",
    "scrollbarSlider.hoverBackground": "#4C566ABB",
    "sideBar.background": "#2E3440",
    "sideBar.border": "#3B4252",
    "sideBar.foreground": "#D8DEE9",
    "sideBarSectionHeader.background": "#3B4252",
    "sideBarSectionHeader.foreground": "#ECEFF4",
    "sideBarTitle.foreground": "#ECEFF4",
    "statusBar.background": "#3B4252",
    "statusBar.foreground": "#ECEFF4",
    "statusBar.debuggingBackground": "#D08770",
    "statusBar.debuggingForeground": "#2E3440",
    "statusBar.noFolderBackground": "#434C5E",
    "statusBarItem.hoverBackground": "#4C566A",
    "tab.activeBackground": "#2E3440",
    "tab.activeForeground": "#ECEFF4",
    "tab.border": "#2E3440",
    "tab.inactiveBackground": "#3B4252",
    "tab.inactiveForeground": "#D8DEE999",
    "terminal.ansiBlack": "#3B4252",
    "terminal.ansiBlue": "#81A1C1",
    "terminal.ansiBrightBlack": "#4C566A",
    "terminal.ansiBrightBlue": "#81A1C1",
    "terminal.ansiBrightCyan": "#8FBCBB",
    "terminal.ansiBrightGreen": "#A3BE8C",
    "terminal.ansiBrightMagenta": "#B48EAD",
    "terminal.ansiBrightRed": "#BF616A",
    "terminal.ansiBrightWhite": "#ECEFF4",
    "terminal.ansiBrightYellow": "#EBCB8B",
    "terminal.ansiCyan": "#88C0D0",
    "terminal.ansiGreen": "#A3BE8C",
    "terminal.ansiMagenta": "#B48EAD",
    "terminal.ansiRed": "#BF616A",
    "terminal.ansiWhite": "#D8DEE9",
    "terminal.ansiYellow": "#EBCB8B",
    "terminal.background": "#2E3440",
    "terminal.foreground": "#D8DEE9",
    "textBlockQuote.background": "#3B4252",
    "textBlockQuote.border": "#4C566A",
    "textCodeBlock.background": "#3B4252",
    "textLink.activeForeground": "#8FBCBB",
    "textLink.foreground": "#88C0D0",
    "titleBar.activeBackground": "#2E3440",
    "titleBar.activeForeground": "#ECEFF4",
    "titleBar.inactiveBackground": "#2E3440",
    "titleBar.inactiveForeground": "#D8DEE999"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#4C566A"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#A3BE8C"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#B48EAD"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#81A1C1"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#8FBCBB"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#88C0D0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#D8DEE9"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#B48EAD"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation"
      ],
      "settings": {
        "foreground": "#81A1C1"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#BF616A"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#88C0D0"
      }
    },
    {
      "name": "Markup inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#A3BE8C"
      }
    },
    {
      "name": "Markup deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#BF616A"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#8FBCBB",
    "enum": "#8FBCBB",
    "function": "#88C0D0",
    "interface": "#8FBCBB",
    "method": "#88C0D0",
    "namespace": "#8FBCBB",
    "parameter": "#D8DEE9",
    "property": "#D8DEE9",
    "type": "#8FBCBB",
    "variable": "#D8DEE9"
  }
}
